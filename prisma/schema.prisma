generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Registration {
  id           Int      @id @default(autoincrement())
  fullName     String
  email        String   @unique
  institution  String
  occupation   String
  sex          String
  location     String
  hearAbout    String
  isLeader     Boolean  @default(false)
  leaderOffice String?
  expectations String
  createdAt    DateTime @default(now())
}
