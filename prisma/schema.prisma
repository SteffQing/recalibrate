generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Registration {
  id                Int      @id @default(autoincrement())
  fullName          String
  email             String   @unique
  phoneNumber       String
  institution       String
  occupation        String
  sex               String
  location          String
  hearAbout         String
  isMinister        Boolean  @default(false)
  ministryDetails   String?
  isFellowshipLeader Boolean  @default(false)
  fellowshipDetails String?
  expectations      String
  createdAt         DateTime @default(now())
}
